<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Content Radar — 週次レポート・記事生成</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="app">
      <nav class="app-main-nav panel" aria-label="アプリの切り替え">
        <div class="app-main-nav-inner">
          <span class="app-main-nav-label">利用するアプリ</span>
          <div class="app-main-nav-buttons">
            <button type="button" data-tab="weekly" class="tab-btn">週次レポート</button>
            <button type="button" data-tab="kyoso" class="tab-btn secondary">競合調査（ランキング抽出）</button>
            <button type="button" data-tab="usecase" class="tab-btn secondary">用途別おすすめ</button>
            <button type="button" data-tab="headings" class="tab-btn secondary">見出し生成（選び方）</button>
            <button type="button" data-tab="article" class="tab-btn secondary">記事生成</button>
          </div>
        </div>
      </nav>

      <!-- 週次レポート（②-A） -->
      <section id="panel-weekly" class="tab-panel">
        <header>
          <h1>週次レポート</h1>
          <p>
            ②-A 市場データAI — 毎週ここから「何が変わったか」「今週何を直すか」を確認します。
            <span class="weekly-demo-badge" id="weekly-phase-badge">Phase 1</span>
          </p>
        </header>

        <section class="panel weekly-header-panel">
          <div class="weekly-header-grid">
            <label class="field weekly-field-inline">
              <span>カテゴリ</span>
              <select id="weekly-category"></select>
              <input
                type="text"
                id="weekly-category-other"
                class="category-other-input"
                placeholder="カテゴリ名を入力"
                hidden
              />
            </label>
            <label class="field weekly-field-inline">
              <span>対象週</span>
              <select id="weekly-week" disabled>
                <option id="weekly-week-option" selected>—</option>
              </select>
            </label>
            <label class="field weekly-field-inline">
              <span>比較</span>
              <select id="weekly-compare">
                <option value="latest" selected>先週の最終（前回取得）</option>
                <option value="prev_month">前月の最終</option>
              </select>
            </label>
          </div>
          <p class="note weekly-status">
            <span class="weekly-status-dot" id="weekly-status-dot" aria-hidden="true"></span>
            <span id="weekly-status-text">読み込み中…</span>
            <span id="weekly-fetch-msg"></span>
          </p>
          <div class="actions">
            <button type="button" id="weekly-fetch">今週のランキングを取得</button>
            <button type="button" class="secondary" id="weekly-to-kyoso">競合調査で詳細を見る</button>
            <a id="weekly-csv-link" class="button-link secondary" href="#" hidden>CSVダウンロード</a>
          </div>
          <p class="field-hint" id="weekly-compare-note" hidden></p>
          <p id="weekly-error" class="error" hidden></p>
        </section>

        <section class="panel weekly-q-panel" id="weekly-q1-panel">
          <h2>商品 — 売れ筋ランキング</h2>
          <div class="ranking-table-wrap">
            <table class="ranking-table weekly-table">
              <thead>
                <tr>
                  <th>順位</th>
                  <th>メーカー名</th>
                  <th>商品名</th>
                  <th>型式</th>
                  <th>Amazon</th>
                  <th>楽天</th>
                  <th>Yahoo</th>
                  <th>コジマ</th>
                  <th>ビック</th>
                </tr>
              </thead>
              <tbody id="weekly-products-tbody">
                <tr><td colspan="9" class="weekly-empty-cell">ランキング未取得</td></tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="panel weekly-q-panel weekly-competitor-panel" id="weekly-competitor-panel">
          <h2>各社記事の確認 <span class="weekly-q-hint">（更新見出し）</span></h2>
          <div class="weekly-competitor-actions">
            <button type="button" class="secondary" id="weekly-competitor-analyze">競合記事を取得・比較</button>
            <button type="button" class="secondary" id="weekly-competitor-setup">競合記事URLを編集</button>
          </div>
          <p class="field-hint" id="weekly-competitor-msg">競合調査タブで記事 URL を保存後、比較を実行してください。</p>
          <p class="field-hint" id="weekly-heading-updates-hint">初回取得後、次回の比較から追加・削除された見出しを表示します。</p>
          <div class="ranking-table-wrap">
            <table class="ranking-table weekly-table">
              <thead>
                <tr>
                  <th>変更</th>
                  <th>競合サイト</th>
                  <th>見出し</th>
                  <th>レベル</th>
                  <th>前回取得</th>
                  <th>参考URL</th>
                </tr>
              </thead>
              <tbody id="weekly-heading-updates-tbody">
                <tr><td colspan="6" class="weekly-empty-cell">更新見出しなし</td></tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="panel weekly-q-panel weekly-change-register-panel" id="weekly-change-register-panel">
          <h2>記事改修を登録</h2>
          <p class="field-hint">今週直した箇所を登録し、「週次レポートを確定」で保存します。来週「改修の結果」に前後比が出ます。</p>
          <div class="weekly-change-form" id="weekly-change-form">
            <label class="field weekly-field-inline">
              <span>改修日</span>
              <input type="date" id="weekly-change-date" />
            </label>
            <label class="field weekly-field-inline">
              <span>対象</span>
              <select id="weekly-change-target">
                <option value="hub|柱記事全体">柱記事全体</option>
              </select>
            </label>
            <label class="field weekly-field-grow">
              <span>改修内容</span>
              <input type="text" id="weekly-change-description" placeholder="例: 選び方に静音性を追加" />
            </label>
            <label class="field weekly-field-inline">
              <span>期待する変化（任意）</span>
              <input type="text" id="weekly-change-expected" placeholder="例: PV増 / 商品詳細遷移増 / CV増" />
            </label>
            <div class="actions">
              <button type="button" class="secondary" id="weekly-change-add">行を追加</button>
            </div>
          </div>
          <p class="field-hint" id="weekly-change-draft-msg"></p>
          <h3 class="weekly-subsection-title">登録済み（今週・確定前）</h3>
          <div class="ranking-table-wrap">
            <table class="ranking-table weekly-table">
              <thead>
                <tr>
                  <th>日付</th>
                  <th>対象</th>
                  <th>内容</th>
                  <th>期待</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="weekly-change-draft-tbody">
                <tr><td colspan="5" class="weekly-empty-cell">まだ登録がありません</td></tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="panel weekly-q-panel weekly-kpi-paste-panel" id="weekly-kpi-paste-panel">
          <h2>KPIを貼り付け（前週・今週）</h2>
          <p class="field-hint"><strong>サーバーには保存しません。</strong>会社の数値はブラウザ上での表示専用です。毎回、前週分と今週分をまとめて貼り付けてください。</p>
          <p class="field-hint">例（各行: 指標 / 前週 / 今週）:<br>
            <code>PV&#9;82000&#9;78700</code><br>
            <code>商品詳細遷移&#9;2115&#9;2185</code><br>
            <code>CV&#9;1720000&#9;1850000</code>
          </p>
          <label class="field">
            <span>貼り付け欄</span>
            <textarea id="weekly-kpi-paste" rows="6" placeholder="ここに前週・今週を貼り付け…"></textarea>
          </label>
          <div class="actions weekly-kpi-paste-actions">
            <button type="button" class="secondary" id="weekly-kpi-preview">解釈を確認</button>
            <button type="button" id="weekly-kpi-apply">表示に反映</button>
          </div>
          <p class="field-hint" id="weekly-kpi-paste-msg"></p>
          <div class="weekly-kpi-preview" id="weekly-kpi-preview-box" hidden>
            <table class="ranking-table weekly-table">
              <thead>
                <tr><th>指標</th><th>前週</th><th>今週</th></tr>
              </thead>
              <tbody id="weekly-kpi-preview-tbody"></tbody>
            </table>
          </div>
        </section>

        <section class="panel weekly-q-panel weekly-change-effects-panel" id="weekly-change-effects-panel">
          <h2>改修の結果 <span class="weekly-q-hint">（貼り付けKPIの前後比）</span></h2>
          <p class="field-hint" id="weekly-change-effects-msg"></p>
          <p class="field-hint">主要KPIの数値は上で貼り付けた内容のみを使い、サーバーへは送りません。</p>
          <div class="ranking-table-wrap">
            <table class="ranking-table weekly-table">
              <thead>
                <tr>
                  <th>判定</th>
                  <th>改修内容</th>
                  <th>対象</th>
                  <th>PV</th>
                  <th>商品詳細遷移</th>
                  <th>CV（売上）</th>
                  <th>理由</th>
                  <th>改修週</th>
                </tr>
              </thead>
              <tbody id="weekly-change-effects-tbody">
                <tr><td colspan="8" class="weekly-empty-cell">先週登録した改修がありません</td></tr>
              </tbody>
            </table>
          </div>
        </section>

        <section class="panel weekly-topics-panel" id="weekly-topics-panel">
          <h2>季節・ニュース・話題</h2>

          <h3 class="weekly-subsection-title">季節・イベント</h3>
          <p class="weekly-season-inline" id="weekly-season-inline">—</p>

          <h3 class="weekly-subsection-title">ニュース・新製品</h3>
          <div class="ranking-table-wrap">
            <table class="ranking-table weekly-table weekly-news-table">
              <thead>
                <tr><th>日付</th><th>内容</th><th>影響</th><th>記事アクション</th></tr>
              </thead>
              <tbody id="weekly-news-tbody">
                <tr><td colspan="4" class="weekly-empty-cell">ニュースなし</td></tr>
              </tbody>
            </table>
          </div>
          <p class="field-hint">※ ニュース・新製品は記事マスタ（`news`）で手動更新</p>

          <h3 class="weekly-subsection-title">SNS・話題</h3>
          <div class="ranking-table-wrap">
            <table class="ranking-table weekly-table">
              <thead>
                <tr><th>日付</th><th>話題</th><th>出典</th><th>リンク</th></tr>
              </thead>
              <tbody id="weekly-sns-tbody">
                <tr><td colspan="4" class="weekly-empty-cell">SNS・話題なし</td></tr>
              </tbody>
            </table>
          </div>
          <p class="field-hint">※ SNS話題は記事マスタ（`snsTopics`）で手動更新</p>

          <h3 class="weekly-subsection-title">検索の話題 <span class="weekly-q-hint">（Google サジェスト）</span></h3>
          <div class="ranking-table-wrap">
            <table class="ranking-table weekly-table">
              <thead>
                <tr><th>順位</th><th>検索クエリ</th></tr>
              </thead>
              <tbody id="weekly-interest-tbody">
                <tr><td colspan="2" class="weekly-empty-cell">読み込み中…</td></tr>
              </tbody>
            </table>
          </div>
          <p class="field-hint" id="weekly-interest-footnote">※ Google サジェストから自動取得</p>
          <p class="field-hint" id="weekly-topics-footnote" hidden></p>
        </section>

        <section class="panel weekly-footer-panel">
          <div class="actions">
            <button type="button" id="weekly-confirm">週次レポートを確定</button>
            <button type="button" class="secondary" id="weekly-to-headings-main">見出し生成へ進む</button>
          </div>
          <p class="field-hint" id="weekly-confirm-msg">
            確定すると今週のスナップショットを保存し、来週の前週比に使います。
          </p>
        </section>
      </section>

      <!-- 用途別担当者おすすめ3選 -->
      <section id="panel-usecase" class="tab-panel" hidden>
        <header>
          <h1>用途別おすすめ</h1>
          <p>
            商品ランキングから用途を3つに分け、コジマ取扱品で担当者おすすめ3選を作り、メーカー公式情報をもとに説明文と機能表を生成します。
          </p>
        </header>

        <section class="panel">
          <h2>1. ランキングを読み込む</h2>
          <p class="field-hint">週次レポートまたは競合調査で取得済みのランキングを使います（新規取得はしません）。</p>
          <div class="weekly-header-grid">
            <label class="field weekly-field-inline">
              <span>カテゴリ</span>
              <select id="usecase-category"></select>
              <input type="text" id="usecase-category-other" class="category-other-input" placeholder="カテゴリ名" hidden />
            </label>
          </div>
          <div class="actions">
            <button type="button" id="usecase-load-ranking">ランキングを読み込む</button>
          </div>
          <p class="field-hint" id="usecase-ranking-msg">未読込</p>
        </section>

        <section class="panel">
          <h2>2. 用途を3つ提案・確定</h2>
          <div class="actions">
            <button type="button" id="usecase-propose" disabled>用途を3つ提案</button>
          </div>
          <p class="field-hint" id="usecase-propose-msg"></p>
          <div id="usecase-use-cases" class="usecase-use-cases"></div>
          <div class="actions">
            <button type="button" id="usecase-confirm-use-cases" disabled>この用途で進む（商品を振り分け）</button>
          </div>
        </section>

        <section class="panel">
          <h2>3. 用途別おすすめ3選</h2>
          <p class="field-hint" id="usecase-assign-msg"></p>
          <div id="usecase-assignments" class="usecase-assignments"></div>
          <div class="actions">
            <button type="button" id="usecase-generate-all" disabled>説明文・機能表を一括生成</button>
          </div>
          <p class="field-hint" id="usecase-generate-msg"></p>
        </section>

        <section class="panel">
          <h2>4. 出力HTML</h2>
          <p class="field-hint">コジマ記事の用途別おすすめブロック向け。コピーしてCMSに貼れます。</p>
          <div class="actions">
            <button type="button" class="secondary" id="usecase-copy-html" disabled>HTMLをコピー</button>
          </div>
          <textarea id="usecase-html-output" rows="16" readonly placeholder="生成後にここに表示されます"></textarea>
          <div id="usecase-html-preview" class="usecase-html-preview generated-article"></div>
        </section>

        <p id="usecase-error" class="error" hidden></p>
      </section>

      <!-- 競合調査 -->
      <section id="panel-kyoso" class="tab-panel" hidden>
        <header>
          <h1>カテゴリ別ランキング取得</h1>
          <p>
            カテゴリ（例: 窓用エアコン）を指定し、まず Gemini で各サイトのランキング URL を自動取得します。
            表示された URL を確認し、必要なら修正してから TOP15 を取得して CSV に出力します。
          </p>
        </header>
        <section class="panel">
          <form id="form-kyoso" class="form">
            <label class="field">
              <span>カテゴリ *</span>
              <select id="kyoso-category" required></select>
              <input
                type="text"
                id="kyoso-category-other"
                class="category-other-input"
                placeholder="例: 空気清浄機"
                hidden
              />
              <p class="field-hint">
                ① 各モールのランキング URL を調べて入力（または Gemini で自動取得）。②「URLを保存」で <code>data/ranking-urls.json</code> にカテゴリ名ごとに記録。③ 以降は週次レポート取得でも自動使用されます。「その他」で新規カテゴリを追加できます。
              </p>
            </label>
            <div class="actions">
              <button type="button" class="secondary" id="kyoso-resolve-urls">ランキング URL を自動取得（Gemini）</button>
              <button type="button" class="secondary" id="kyoso-save-urls">URLを保存</button>
            </div>
            <div id="kyoso-url-panel" class="field" hidden>
              <span>ランキング一覧 URL（確認・修正可）</span>
              <p class="field-hint" id="kyoso-url-notes"></p>
              <p class="field-hint" id="kyoso-url-saved-hint"></p>
              <label class="field nested-field">
                <span class="field-sub">Amazon</span>
                <input type="url" id="kyoso-url-amazon" placeholder="https://www.amazon.co.jp/gp/bestsellers/..." />
              </label>
              <label class="field nested-field">
                <span class="field-sub">楽天</span>
                <input type="url" id="kyoso-url-rakuten" placeholder="https://ranking.rakuten.co.jp/daily/..." />
              </label>
              <label class="field nested-field">
                <span class="field-sub">Yahoo!</span>
                <input type="url" id="kyoso-url-yahoo" placeholder="https://shopping.yahoo.co.jp/searchranking?..." />
              </label>
              <label class="field nested-field">
                <span class="field-sub">コジマネット</span>
                <input type="url" id="kyoso-url-kojima" placeholder="https://www.kojima.net/ec/ranking.html?..." />
              </label>
              <label class="field nested-field">
                <span class="field-sub">ビックカメラ</span>
                <input type="url" id="kyoso-url-bic" placeholder="https://www.biccamera.com/bc/ranking/..." />
              </label>
            </div>
            <div class="actions">
              <button type="submit" id="kyoso-submit" disabled>① ランキング取得・横断比較</button>
              <button type="button" class="secondary" id="kyoso-reset">リセット</button>
            </div>
          </form>
          <p id="kyoso-error" class="error" hidden></p>
        </section>

        <section class="panel" id="kyoso-article-panel">
          <h2>競合記事 URL（記事改修用）</h2>
          <p class="field-hint">
            各サイトのおすすめ記事 URL をカテゴリごとに保存します（<code>data/competitor-articles.json</code>）。
            保存後「競合記事を取得・比較」で見出し構成を自社柱記事と比較できます。
          </p>
          <div id="kyoso-article-url-list" class="competitor-article-list"></div>
          <div class="actions">
            <button type="button" class="secondary" id="kyoso-article-add">行を追加</button>
            <button type="button" class="secondary" id="kyoso-article-save">記事URLを保存</button>
            <button type="button" id="kyoso-article-analyze">競合記事を取得・比較</button>
          </div>
          <p class="field-hint" id="kyoso-article-saved-hint"></p>
          <p id="kyoso-article-error" class="error" hidden></p>
          <div id="kyoso-article-result" class="generated-block" hidden>
            <h3>競合記事 見出し比較</h3>
            <p class="note" id="kyoso-article-meta"></p>
            <div class="ranking-table-wrap">
              <table class="ranking-table">
                <thead>
                  <tr>
                    <th>優先</th>
                    <th>競合サイト</th>
                    <th>見出し</th>
                    <th>レベル</th>
                    <th>理由</th>
                    <th>参考URL</th>
                  </tr>
                </thead>
                <tbody id="kyoso-article-tbody"></tbody>
              </table>
            </div>
          </div>
        </section>
        <section id="kyoso-result" class="panel" hidden>
          <h2>取得結果</h2>
          <div class="result-actions">
            <button type="button" class="secondary" id="kyoso-clear">クリア</button>
          </div>
          <p class="note" id="kyoso-meta"></p>
          <div class="generated-block">
            <div class="ranking-table-wrap">
              <table class="ranking-table">
                <thead>
                  <tr>
                    <th>取得元種別</th>
                    <th>取得元</th>
                    <th>順位</th>
                    <th>メーカー</th>
                    <th>商品名</th>
                    <th>URL</th>
                  </tr>
                </thead>
                <tbody id="kyoso-tbody"></tbody>
              </table>
            </div>
          </div>
          <div class="generated-block">
            <h3>横断比較（型番ベース）</h3>
            <p class="note" id="kyoso-composite-meta"></p>
            <div class="ranking-table-wrap">
              <table class="ranking-table">
                <thead>
                  <tr>
                    <th>型番</th>
                    <th>メーカー</th>
                    <th>Amazon</th>
                    <th>楽天</th>
                    <th>Yahoo!</th>
                    <th>コジマ</th>
                    <th>ビック</th>
                    <th>掲載数</th>
                    <th>平均順位</th>
                    <th>代表商品名</th>
                  </tr>
                </thead>
                <tbody id="kyoso-composite-tbody"></tbody>
              </table>
            </div>
          </div>
          <div id="kyoso-themed-blocks" class="generated-block"></div>
          <div id="kyoso-features-block" class="generated-block" hidden>
            <h3>③ 見出し候補（総合ランキングから需要分析）</h3>
            <p class="note" id="kyoso-features-meta"></p>
            <ul id="kyoso-features-list" class="feature-candidate-list"></ul>
            <div class="actions">
              <button type="button" class="secondary" id="kyoso-to-headings">見出し生成タブへ（候補を引き継ぐ）</button>
            </div>
          </div>
          <div id="kyoso-theme-select-panel" class="generated-block" hidden>
            <h3>④ 見出し別ランキングのテーマ選択</h3>
            <p class="field-hint">
              テーマ1「総合おすすめ」は②で確定済みです。下記の需要候補からテーマ2・3を選び、見出しごと最大5件のランキングを作成します。
            </p>
            <label class="field nested-field">
              <span class="field-sub">テーマ2（見出し用）</span>
              <select id="kyoso-theme-2" required></select>
            </label>
            <label class="field nested-field">
              <span class="field-sub">テーマ3（見出し用）</span>
              <select id="kyoso-theme-3" required></select>
            </label>
            <div class="actions">
              <button type="button" id="kyoso-build-themed">見出し別ランキングを作成（テーマ2・3）</button>
            </div>
          </div>
        </section>
      </section>

      <!-- 見出し生成 -->
      <section id="panel-headings" class="tab-panel" hidden>
        <header>
          <h1>見出し生成（選び方）</h1>
          <p>
            商品のおすすめ見出しは「用途別おすすめ」で作成します。ここでは参考URLを踏まえ、<strong>選び方・比較の判断軸</strong>中心の見出し（H2×3・各H3×3）を作ります。
          </p>
        </header>
        <section class="panel">
          <h2>週次・競合からの取り込み</h2>
          <p class="field-hint">
            週次・競合のニーズを「選び方の観点」として取り込みます。商品紹介の見出しには使いません。
          </p>
          <div class="actions">
            <button type="button" id="headings-import-sources">
              週次・競合の結果を取り込む
            </button>
            <button type="button" class="secondary" id="headings-to-article">
              記事生成へ引き継ぐ
            </button>
          </div>
          <p class="field-hint" id="headings-bridge-msg"></p>
        </section>
        <section class="panel">
          <form id="form-headings" class="form">
            <label class="field">
              <span>キーワード *</span>
              <input type="text" id="headings-keyword" required placeholder="例: 冷蔵庫 選び方" />
            </label>
            <label class="field">
              <span>参考URL（推奨）</span>
              <input type="url" id="headings-ref-url" placeholder="選び方記事の参考URL（構成の手本）" />
            </label>
            <p class="field-hint">参考URLの「選び方」構成を最優先で参照します。商品おすすめ部分は使いません。</p>
            <label class="field">
              <span>他社URL 1（任意）</span>
              <input type="url" id="headings-url1" placeholder="https://example.com/article" />
            </label>
            <label class="field">
              <span>他社URL 2（任意）</span>
              <input type="url" id="headings-url2" placeholder="https://example.com/article" />
            </label>
            <label class="field">
              <span>他社URL 3（任意）</span>
              <input type="url" id="headings-url3" placeholder="https://example.com/article" />
            </label>
            <div id="headings-candidates-panel" class="field">
              <span>選び方の観点候補（最大5件）</span>
              <p class="field-hint" id="headings-candidates-hint">
                容量・サイズ・機能・省エネなど、購入判断の軸を入力（または週次・競合から取り込み）してください。
              </p>
              <label class="field nested-field">
                <span class="field-sub">観点 1</span>
                <input type="text" id="headings-candidate-1" placeholder="例: 容量の目安の見方" />
              </label>
              <label class="field nested-field">
                <span class="field-sub">観点 2</span>
                <input type="text" id="headings-candidate-2" placeholder="例: 設置スペースとサイズの測り方" />
              </label>
              <label class="field nested-field">
                <span class="field-sub">観点 3</span>
                <input type="text" id="headings-candidate-3" placeholder="例: 省エネ・電気代の比較ポイント" />
              </label>
              <label class="field nested-field">
                <span class="field-sub">観点 4</span>
                <input type="text" id="headings-candidate-4" placeholder="例: 扉の開き方・使い勝手" />
              </label>
              <label class="field nested-field">
                <span class="field-sub">観点 5</span>
                <input type="text" id="headings-candidate-5" placeholder="例: 失敗しやすい選び方" />
              </label>
            </div>
            <div class="actions">
              <button type="submit" id="headings-submit">選び方見出しを生成</button>
              <button type="button" class="secondary" id="headings-reset">リセット</button>
            </div>
          </form>
          <p id="headings-error" class="error" hidden></p>
        </section>
        <section id="headings-result" class="panel" hidden>
          <h2>見出し生成結果</h2>
          <div class="result-actions">
            <button type="button" class="secondary" id="headings-copy">すべてコピー</button>
            <button type="button" class="secondary" id="headings-clear">クリア</button>
          </div>
          <p id="headings-copy-msg" class="field-hint" hidden></p>
          <div id="headings-warnings" class="warning" hidden></div>
          <div id="headings-body" class="generated-article"></div>
        </section>
        <!-- H4見出し生成 -->
        <section id="sub-headings-panel" class="panel" hidden>
          <h2>H4見出し生成</h2>
          <p class="field-hint">生成されたH3見出しをクリック、またはH3を入力してH4小見出しを生成します。</p>
          <form id="form-sub-headings" class="form">
            <label class="field">
              <span>対象H3見出し *</span>
              <input type="text" id="sub-headings-h3" required placeholder="H4を生成するH3見出しを入力" />
            </label>
            <div class="actions">
              <button type="submit" id="sub-headings-submit">H4見出しを生成</button>
              <button type="button" class="secondary" id="sub-headings-clear">クリア</button>
            </div>
          </form>
          <p id="sub-headings-error" class="error" hidden></p>
          <div id="sub-headings-result" hidden>
            <div id="sub-headings-body" class="generated-article"></div>
          </div>
        </section>
      </section>

      <!-- 記事生成 -->
      <section id="panel-article" class="tab-panel" hidden>
        <header>
          <h1>AI記事生成アプリ</h1>
          <p>
            週次・競合の他社URLと、見出し生成結果を引き継いで記事の叩き台を作成します。
          </p>
        </header>
        <section class="panel">
          <div class="actions">
            <button type="button" class="secondary" id="article-import-sources">
              週次・競合の結果を取り込む
            </button>
            <button type="button" class="secondary" id="article-import-headings">
              見出し結果を取り込む
            </button>
          </div>
          <p class="field-hint" id="article-bridge-msg"></p>
          <form id="form-article" class="form">
            <label class="field">
              <span>キーワード *</span>
              <input type="text" id="article-keyword" required placeholder="例: AI ライティング" />
            </label>
            <label class="field">
              <span>タイトル（任意）</span>
              <input type="text" id="article-title" placeholder="例: AIによる記事コンテンツ作成" />
            </label>
            <label class="field">
              <span>H2:見出し１（任意）</span>
              <input type="text" id="article-h2" placeholder="例: AIで記事を作成してみよう" />
            </label>
            <label class="field">
              <span>H3:見出し１（任意）</span>
              <input type="text" id="article-h3-1" />
            </label>
            <label class="field">
              <span>H3:見出し2（任意）</span>
              <input type="text" id="article-h3-2" />
            </label>
            <label class="field">
              <span>H3:見出し3（任意）</span>
              <input type="text" id="article-h3-3" />
            </label>
            <label class="field">
              <span>H3:見出し4（任意）</span>
              <input type="text" id="article-h3-4" />
            </label>
            <label class="field">
              <span>H3:見出し5（任意）</span>
              <input type="text" id="article-h3-5" />
            </label>
            <div id="article-h4-panel" class="field">
              <span>H4で記事生成（任意 — H4が空の場合はH3で生成）</span>
              <p class="field-hint">
                特定のH3の下にH4見出しを入力すると、H4単位で記事が生成されます。
              </p>
              <label class="field nested-field">
                <span class="field-sub">対象H3見出し</span>
                <input type="text" id="article-h3-target" placeholder="H4を配置するH3見出しを入力" />
              </label>
              <label class="field nested-field">
                <span class="field-sub">H4:見出し1</span>
                <input type="text" id="article-h4-1" />
              </label>
              <label class="field nested-field">
                <span class="field-sub">H4:見出し2</span>
                <input type="text" id="article-h4-2" />
              </label>
              <label class="field nested-field">
                <span class="field-sub">H4:見出し3</span>
                <input type="text" id="article-h4-3" />
              </label>
              <label class="field nested-field">
                <span class="field-sub">H4:見出し4</span>
                <input type="text" id="article-h4-4" />
              </label>
              <label class="field nested-field">
                <span class="field-sub">H4:見出し5</span>
                <input type="text" id="article-h4-5" />
              </label>
            </div>
            <label class="field">
              <span>他社URL 1</span>
              <input type="url" id="article-url1" />
            </label>
            <label class="field">
              <span>他社URL 2</span>
              <input type="url" id="article-url2" />
            </label>
            <label class="field">
              <span>他社URL 3</span>
              <input type="url" id="article-url3" />
            </label>
            <label class="field">
              <span>参考URL</span>
              <input type="url" id="article-ref-url" />
            </label>
            <div class="field">
              <span>生成するブロック（H2×1・H3×最大5は毎回生成）</span>
              <p class="field-hint">
                見出しごとに何度か生成する場合、導入文・まとめは最初の1回だけチェックして生成するのがおすすめです。
              </p>
              <label class="checkbox-field">
                <input type="checkbox" id="article-gen-intro" />
                <span>導入文を作成する</span>
              </label>
              <label class="checkbox-field">
                <input type="checkbox" id="article-gen-summary" />
                <span>まとめを作成する</span>
              </label>
            </div>
            <div class="actions">
              <button type="submit" id="article-submit">記事を生成</button>
              <button type="button" class="secondary" id="article-reset">リセット</button>
            </div>
          </form>
          <p id="article-error" class="error" hidden></p>
        </section>
        <section id="article-result" class="panel" hidden>
          <h2>記事生成結果</h2>
          <div class="result-actions">
            <button type="button" class="secondary" id="article-clear">クリア</button>
          </div>
          <div id="article-warnings" class="warning" hidden></div>
          <div id="article-body" class="generated-article"></div>
        </section>
      </section>
    </div>
    <script src="/js/main.js"></script>
    <script src="/js/weeklyReport.js"></script>
    <script src="/js/useCaseRecommend.js"></script>
  </body>
</html>
