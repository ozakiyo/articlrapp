PORT=3050
# AI プロバイダ既定（gemini | cursor）。未指定時は gemini
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.5-flash-lite
# Cursor モード用（UI またはリクエストで cursor を選んだとき）
# CURSOR_API_KEY=your-cursor-api-key-here
# Cursor モデルは Auto を既定にする
CURSOR_MODEL=auto
# CURSOR_CWD=.
# Cursor ローカル状態の保存先（未指定時 data/cursor-agents。SQLite 不要の JSONL）
# CURSOR_STORE_DIR=./data/cursor-agents
# 推奨: Node.js >= 22.13（@cursor/sdk の engines）
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASSWORD=強力なパスワードに変更してください
# RANKING_RESULT_LIMIT=50
# CATEGORY_RANKING_TOP=15
# CSV は exports/rankings/ に保存されます
# テーマ別ランキングの1テーマあたり最大件数（既定 5、記事は1〜3位から選ぶ想定）
# THEME_RANKING_TOP=5
# 見出し候補に使う機能ピックアップの最大件数（既定 5）
# USER_FEATURE_PICK_MAX=5
