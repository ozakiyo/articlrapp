# コピーして server/.env として保存してください（.gitignore 対象）
# ポートが埋まっているときは 3051 などに変更し、client/vite.config.js の proxy target も合わせてください。
PORT=3050
# 本番推奨: 次の2つを設定すると HTML・静的ファイルにベーシック認証がかかる（/api は対象外。未設定のときは認証なし）
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASSWORD=強力なパスワードに変更してください
# ランキングAPIの返却件数上限（1〜200、既定 50）
# RANKING_RESULT_LIMIT=50
# ビックカメラ取得で Playwright がタイムアウト／Bot対策に引っかかるとき: システムの Google Chrome を使う（要インストール）
# BICCAMERA_PLAYWRIGHT_CHANNEL=chrome
# Docker 等で Chromium が起動しないとき
# PLAYWRIGHT_CHROMIUM_NO_SANDBOX=1
